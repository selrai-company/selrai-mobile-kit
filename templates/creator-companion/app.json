{
  "expo": {
    "name": "Creator Companion",
    "slug": "creator-companion",
    "version": "0.1.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png.placeholder",
    "splash": {
      "image": "./assets/splash.png.placeholder",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "creator-companion",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png.placeholder",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Creator Companion uses the camera once, to scan the pair QR your operator generated."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
